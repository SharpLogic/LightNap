{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Information"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite", // "SqlServer" or "Sqlite" or "InMemory"
    "AutomaticallyApplyEfMigrations": true
  },
  "DataProtection": {
    "Provider": "Local", // "Azure" or "Local" or "Ephemeral"
    "Local": {
      "CertificateName": "localhost"
    },
    "Azure": {
      "KeyVaultUrl": "https://your-vault.vault.azure.net/",
      "BlobUrl": "https://yourstorageaccount.blob.core.windows.net/yourcontainer/yourblob"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=LightNap.db",
    //"DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=LightNap;Trusted_Connection=True;MultipleActiveResultSets=true",
    "Redis": "localhost:6379"
  },
  "UseDistributedMode": false,
  "Cache": {
    "ExpirationMinutes": 5
  },
  "StaticContent": {
    // When true the server renders Markdown content to HTML on read so SEO/email
    // consumers do not need a JS context. The browser still receives the original
    // format header set to "Html" after rendering. Default is false (client-side
    // rendering via ngx-markdown).
    "RenderMarkdownServerSide": false
  },
  "ApplicationInsights": {
    // When true the WebApi wires up the Application Insights SDK and forwards exceptions
    // (and any future custom events) through ITelemetryClient. Default is false; with that
    // setting ITelemetryClient is bound to a no-op implementation.
    "Enabled": false
  },
  "Authentication": {
    "LogOutInactiveDeviceDays": 30,
    "RequireEmailVerification": false,
    "RequireTwoFactorForNewUsers": false
  },
  "SeededUsers": {
    "Administrator": [
      {
        "Email": "Admin@lightnap.azurewebsites.net",
        "UserName": "Admin",
        "Password": "P@ssw0rd"
      }
    ],
    "ContentEditor": [
      {
        "Email": "ContentEditor@lightnap.azurewebsites.net",
        "UserName": "ContentEditor",
        "Password": "P@ssw0rd"
      }
    ],
    "": [
      {
        "Email": "RegularUser@lightnap.azurewebsites.net",
        "UserName": "RegularUser",
        "Password": "P@ssw0rd"
      }
    ]
  },
  "Jwt": {
    "Key": "Any 32+ Character Key (Like A Guid)",
    "Issuer": "https://www.yourdomain.com",
    "Audience": "https://www.yourdomain.com",
    "ExpirationMinutes": 120
  },
  "Email": {
    "Provider": "LogToConsole", // "LogToConsole" or "Smtp"
    "FromEmail": "hello@yourdomain.com",
    "FromDisplayName": "Your Email Display Name",
    "SiteUrlRootForLinks": "http://localhost:4200/",
    "Smtp": {
      "Host": "smtp.sendgrid.net",
      "Port": 587,
      "EnableSsl": true,
      "User": "apikey",
      "Password": "PutYourSendGridApiKeyHere"
    }
  },
  "RateLimiting": {
    "GlobalPermitLimit": 300,
    "AuthPermitLimit": 30,
    "ContentPermitLimit": 200,
    "RegistrationPermitLimit": 10
  },
  "Idempotency": {
    // How long a cached response is replayed for repeated calls with the same Idempotency-Key.
    "Ttl": "01:00:00"
  },
  "Captcha": {
    // "None" (default, NoOp) | "Turnstile" | "RecaptchaV2" | "RecaptchaV3"
    "Provider": "None",
    "RejectOnProviderError": true
    // When Provider is not "None", add the matching sub-section, e.g.:
    // "Turnstile": { "SiteKey": "...", "SecretKey": "..." }
    // "RecaptchaV2": { "SiteKey": "...", "SecretKey": "..." }
    // "RecaptchaV3": { "SiteKey": "...", "SecretKey": "...", "MinScore": 0.5 }
  }
}